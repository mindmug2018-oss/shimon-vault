"""
ansible/roles/monitoring_stack/templates/telegram_relay.py.j2

Tiny FastAPI relay that receives Alertmanager webhooks and forwards
them to the Telegram Bot API.

Alertmanager doesn't support Telegram natively, so we run this small
service alongside the monitoring stack. Alertmanager POSTs to
http://telegram-relay:8001/alert → this service reformats it and
calls the Telegram Bot API sendMessage.
"""

import os
import json
import requests
from fastapi import FastAPI, Request
from datetime import datetime

app = FastAPI(title="ShimonVault Telegram Relay")

TELEGRAM_BOT_TOKEN = os.environ["TELEGRAM_BOT_TOKEN"]
TELEGRAM_CHAT_ID   = os.environ["TELEGRAM_CHAT_ID"]
TELEGRAM_API_URL   = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"


@app.post("/alert")
async def receive_alert(request: Request):
    """Receive Alertmanager webhook and forward to Telegram."""
    payload = await request.json()
    alerts  = payload.get("alerts", [])
    status  = payload.get("status", "unknown")  # "firing" or "resolved"

    for alert in alerts:
        message = format_alert(alert, status)
        send_telegram(message)

    return {"forwarded": len(alerts)}


@app.get("/health")
async def health():
    return {"status": "ok"}


def format_alert(alert: dict, status: str) -> str:
    """Convert Alertmanager alert payload to a readable Telegram message."""
    labels      = alert.get("labels", {})
    annotations = alert.get("annotations", {})
    alert_name  = labels.get("alertname", "Unknown Alert")
    instance    = labels.get("instance", "unknown")
    severity    = labels.get("severity", "unknown")

    if status == "resolved":
        emoji = "✅"
        header = f"*RECOVERED — ShimonVault*"
    elif severity == "critical":
        emoji = "🚨"
        header = f"*CRITICAL ALERT — ShimonVault*"
    else:
        emoji = "⚠️"
        header = f"*WARNING — ShimonVault*"

    description = annotations.get("description", annotations.get("summary", alert_name))
    timestamp   = datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")

    return (
        f"{emoji} {header}\n"
        f"Alert: {alert_name}\n"
        f"Instance: `{instance}`\n"
        f"Severity: {severity}\n"
        f"Status: {status.upper()}\n"
        f"{description}\n"
        f"Time: {timestamp}"
    )


def send_telegram(message: str):
    """Send message to Telegram. Errors are logged but not raised."""
    try:
        resp = requests.post(TELEGRAM_API_URL, json={
            "chat_id":    TELEGRAM_CHAT_ID,
            "text":       message,
            "parse_mode": "Markdown",
        }, timeout=5)
        if resp.status_code != 200:
            print(f"Telegram API error: {resp.status_code} {resp.text}")
    except Exception as exc:
        print(f"Telegram send failed: {exc}")


if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8001)
