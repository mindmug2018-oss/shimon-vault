# ─────────────────────────────────────────────────────────────
# monitoring/.env.example
# Copy to monitoring/.env and fill in real values.
# This file is used by docker-compose.yml on your on-prem server.
# ─────────────────────────────────────────────────────────────

# PostgreSQL replica password (must match RDS password)
DB_PASSWORD=REPLACE_WITH_YOUR_DB_PASSWORD

# Grafana admin password
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE

# Telegram bot token and chat ID
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID
